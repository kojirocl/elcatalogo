<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="elcatalogo.sqlite" readonly="0" foreign_keys="0" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2424"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="users" custom_title="0" dock_id="1" table="4,5:mainusers"/><dock_state state="000000ff00000000fd00000001000000020000043000000223fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000004300000012400ffffff0000026d0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="comentarios" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="37"/><column index="2" value="300"/><column index="3" value="77"/><column index="4" value="85"/><column index="5" value="92"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="45"/><column index="2" value="126"/><column index="3" value="300"/><column index="4" value="149"/><column index="5" value="125"/><column index="6" value="67"/><column index="7" value="115"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">BEGIN TRANSACTION;

-- ============================================
-- PASO 1: Respaldar tabla actual (por seguridad)
-- ============================================
CREATE TABLE &quot;users_backup&quot; AS SELECT * FROM &quot;users&quot;;

-- ============================================
-- PASO 2: Crear nueva tabla con la estructura mejorada
-- ============================================
DROP TABLE IF EXISTS &quot;users_new&quot;;
CREATE TABLE &quot;users_new&quot; (
    &quot;idUser&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
    &quot;email&quot; TEXT NOT NULL UNIQUE,
    &quot;password&quot; TEXT NOT NULL,
    &quot;fecha_ingreso&quot; TEXT DEFAULT CURRENT_TIMESTAMP,
    &quot;codigo_verificacion&quot; TEXT,        -- Cambiado a TEXT
    &quot;verificado&quot; INTEGER DEFAULT 0,
    &quot;fecha_exp_codigo&quot; TEXT,            -- Nuevo (para código 6 dígitos)
    &quot;token_recuperacion&quot; TEXT,           -- Nuevo
    &quot;fecha_exp_recuperacion&quot; TEXT,       -- Nuevo
    &quot;intentos_fallidos&quot; INTEGER DEFAULT 0,
    &quot;ultimo_acceso&quot; TEXT                  -- Nuevo
);

-- ============================================
-- PASO 3: Migrar datos existentes
-- ============================================
INSERT INTO &quot;users_new&quot; (
    idUser,
    email,
    password,
    fecha_ingreso,
    codigo_verificacion,
    verificado,
    intentos_fallidos,
    ultimo_acceso
)
SELECT 
    idUser,
    email,
    password,
    CASE 
        -- Convertir timestamp UNIX a formato ISO si existe
        WHEN fecha_ingreso IS NOT NULL AND fecha_ingreso != '' 
        THEN datetime(fecha_ingreso, 'unixepoch')
        ELSE datetime('now', '-30 days')  -- Fecha aleatoria para los NULL
    END as fecha_ingreso,
    CASE 
        -- Convertir código numérico a TEXT con formato de 6 dígitos
        WHEN codigo_verificacion IS NOT NULL 
        THEN printf('%06d', codigo_verificacion)
        ELSE NULL
    END as codigo_verificacion,
    COALESCE(verificado, 0) as verificado,
    0 as intentos_fallidos,  -- Por defecto 0
    CASE 
        -- Si tienen fecha_ingreso, usar esa + random, si no, fecha random
        WHEN fecha_ingreso IS NOT NULL 
        THEN datetime(fecha_ingreso, 'unixepoch', '+' || (abs(random() % 30) || ' days'))
        ELSE datetime('now', '-' || (abs(random() % 60) || ' days'))
    END as ultimo_acceso
FROM &quot;users&quot;;

-- ============================================
-- PASO 4: Actualizar valores específicos
-- ============================================

-- Para usuarios con verificado=1, ponerles un ultimo_acceso más reciente
UPDATE &quot;users_new&quot; 
SET ultimo_acceso = datetime('now', '-' || (abs(random() % 10) || ' days'))
WHERE verificado = 1 AND ultimo_acceso IS NULL;

-- Para usuarios sin fecha_ingreso, ponerles una fecha coherente
UPDATE &quot;users_new&quot; 
SET fecha_ingreso = datetime('now', '-90 days')
WHERE fecha_ingreso IS NULL OR fecha_ingreso = '';

-- ============================================
-- PASO 5: Renombrar tablas
-- ============================================
DROP TABLE IF EXISTS &quot;users_old&quot;;
ALTER TABLE &quot;users&quot; RENAME TO &quot;users_old&quot;;
ALTER TABLE &quot;users_new&quot; RENAME TO &quot;users&quot;;

-- ============================================
-- PASO 6: Crear índices
-- ============================================
CREATE INDEX idx_users_email ON users(email);
CREATE INDEX idx_users_codigo ON users(codigo_verificacion);
CREATE INDEX idx_users_recuperacion ON users(token_recuperacion);
CREATE INDEX idx_users_verificado ON users(verificado);

COMMIT;

-- ============================================
-- PASO 7: Verificar la migración
-- ============================================
SELECT 'Registros migrados: ' || COUNT(*) as total FROM users;
SELECT 'Fecha más antigua: ' || MIN(fecha_ingreso) as min_fecha FROM users;
SELECT 'Fecha más reciente: ' || MAX(fecha_ingreso) as max_fecha FROM users;
SELECT 
    verificado,
    COUNT(*) as cantidad,
    MIN(fecha_ingreso) as primera_fecha,
    MAX(ultimo_acceso) as ultimo_acceso
FROM users 
GROUP BY verificado;</sql><current_tab id="0"/></tab_sql></sqlb_project>
