rmats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="perfil" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="45"/><column index="2" value="143"/><column index="3" value="63"/><column index="4" value="300"/><column index="5" value="103"/><column index="6" value="90"/><column index="7" value="95"/><column index="8" value="43"/><column index="9" value="72"/><column index="10" value="52"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sessions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="215"/><column index="2" value="475"/><column index="3" value="79"/><column index="4" value="300"/><column index="5" value="87"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="suscripcion" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="87"/><column index="3" value="35"/><column index="4" value="55"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tag_perfil" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="39"/><column index="2" value="44"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tags" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="39"/><column index="2" value="63"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="trafico" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="61"/><column index="3" value="87"/><column index="4" value="39"/><column index="5" value="58"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="44"/><column index="2" value="165"/><column index="3" value="300"/><column index="4" value="88"/><column index="5" value="139"/><column index="6" value="64"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT perfil.* , media.ubicacion
            FROM perfil
            LEFT JOIN media ON perfil.idFotoPerfil = media.id
            LEFT JOIN tag_perfil ON perfil.idUser = tag_perfil.idUser 
            WHERE tag_perfil.idTag IN (5) AND perfil.activo=1 AND perfil.idGrupo=5
            GROUP BY perfil.idUser</sql><sql name="SQL 2">SELECT 
    strftime('%Y', datetime(fecha, 'unixepoch')) AS anio, 
    strftime('%m', datetime(fecha, 'unixepoch')) AS mes, 
    SUM(visita) AS total_visitas,
    SUM(contacto) AS total_contactos
FROM trafico
WHERE idUsuario = 2  -- Reemplaza con el ID del usuario
GROUP BY anio, mes
ORDER BY anio, mes;</sql><sql name="SQL 3">SELECT * from tag_perfil where tag_perfil.idTag IN (1,30)</sql><sql name="SQL 4"> SELECT 
        strftime('%Y-%m', datetime(fecha, 'unixepoch')) AS periodo,
        SUM(visita) AS total_visitas,
        SUM(contacto) AS total_contactos
    FROM trafico
    WHERE idUsuario = 2
    GROUP BY periodo
    ORDER BY periodo</sql><sql name="SQL 5">SELECT media.*, 
            COUNT(me_gusta.id) AS total_me_gusta,
            MAX(CASE WHEN me_gusta.idUser_origen = 20 THEN 1 ELSE 0 END) AS si_me_gusta
            FROM media
            LEFT JOIN me_gusta ON media.id = me_gusta.idMedia
            WHERE media.idUser = 2
            GROUP BY media.id;</sql><sql name="SQL 6">SELECT perfil.*, media.ubicacion AS foto_perfil 
            FROM perfil 
            LEFT JOIN media ON perfil.idFotoPerfil = media.id
            WHERE perfil.activo = 1;</sql><sql name="SQL 7">SELECT * FROM comentarios WHERE idUserDestino=4</sql><sql name="SQL 8">SELECT t.&quot;idTag&quot;, t.&quot;tag&quot;, COUNT(*) AS frecuencia
FROM &quot;tag_perfil&quot; tp
JOIN &quot;tags&quot; t ON tp.&quot;idTag&quot; = t.&quot;idTag&quot;
GROUP BY t.&quot;idTag&quot;, t.&quot;tag&quot;
ORDER BY frecuencia DESC
LIMIT 20;</sql><current_tab id="7"/></tab_sql></sqlb_project>
