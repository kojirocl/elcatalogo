n_widths><column index="1" value="47"/><column index="2" value="44"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="media" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="44"/><column index="3" value="541"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="perfil" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="45"/><column index="2" value="143"/><column index="3" value="63"/><column index="4" value="300"/><column index="5" value="103"/><column index="6" value="44"/><column index="7" value="95"/><column index="8" value="43"/><column index="9" value="72"/><column index="10" value="52"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="trafico" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="61"/><column index="3" value="87"/><column index="4" value="39"/><column index="5" value="58"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT perfil.*, 
       media.ubicacion, 
       COUNT(me_gusta.id) AS total_me_gusta
FROM perfil
LEFT JOIN media ON perfil.idFotoPerfil = media.id
LEFT JOIN me_gusta ON perfil.idUser = me_gusta.idUser_destino
WHERE perfil.activo = 1
GROUP BY perfil.idUser, media.ubicacion;</sql><sql name="SQL 2">SELECT media.*, count(me_gusta.id) as total_me_gusta  FROM media LEFT JOIN me_gusta ON media.id=me_gusta.idMedia WHERE media.idUser=4 GROUP BY media.id;
SELECT me_gusta.* FROM me_gusta LEFT JOIN media ON media.id=me_gusta.idMedia WHERE me_gusta.idUser_origen=2;</sql><sql name="SQL 3">SELECT 
    media.*, 
    COUNT(me_gusta.id) AS total_me_gusta,
    MAX(CASE WHEN me_gusta.idUser_origen = 3 THEN 1 ELSE 0 END) AS si_me_gusta
FROM media
LEFT JOIN me_gusta ON media.id = me_gusta.idMedia
WHERE media.idUser = 2
GROUP BY media.id;</sql><sql name="SQL 4">SELECT perfil.*, media.ubicacion AS foto_perfil 
FROM perfil 
LEFT JOIN media ON perfil.idFotoPerfil = media.id</sql><current_tab id="2"/></tab_sql></sqlb_project>
